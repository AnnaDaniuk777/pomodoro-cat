{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["ES2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "types": ["node"],
    "outDir": "dist-electron",
    "rootDir": "electron"
  },
  "include": ["electron/**/*.ts"]
}
